{
    "name": "main",
    "layer": "top",
    "position": "bottom",
    "modules-left": ["sway/workspaces", "custom/updates", "custom/spotify"],
    "modules-center": ["sway/window"],
    "modules-right": [
        "custom/weather",
        "custom/disk",
        "custom/wifi",
        "custom/vpn",
        "custom/bluetooth",
        "custom/volume",
        "clock#date",
        "clock#time"
    ],

    "sway/workspaces": {
        "format": "{name} {windows}",
        "format-window-separator": " · ",
        "window-rewrite-default": "{app_id}",
        "window-rewrite": {
            "firefox": "firefox",
            "kitty": "kitty",
            "spotify": "spotify",
            "thunar": "files",
            "pavucontrol": "audio",
            "org.gnome.Nautilus": "files"
        }
    },

    "sway/window": {
        "format": "{}",
        "max-length": 80
    },

    "custom/updates": {
        "exec": "n=$(checkupdates 2>/dev/null | wc -l); echo \"🗞️ $n updates available\"",
        "exec-if": "checkupdates 2>/dev/null | grep -q .",
        "interval": 300,
        "on-click": "kitty -e fish -C 'echo paru -Syu && paru -Syu'"
    },

    "custom/spotify": {
        "exec": "~/scripts/spotify.sh",
        "interval": 1,
        "format": "🎶 <i>{}</i>"
    },

    "custom/wifi": {
        "exec": "ssid=$(iw dev wlan0 link | awk -F': ' '/SSID/ {print $2}' | head -1); ip=$(ip -4 -o addr show wlan0 2>/dev/null | awk '{print $4}' | cut -d/ -f1); echo \"🛜 ${ssid:-disconnected} (${ip:-none})\"",
        "interval": 10
    },

    "custom/vpn": {
        "exec": "out=''; for i in $(ip -d link show | awk '/^[0-9]+:/{gsub(\":\",\"\",$2); n=$2} /wireguard/{print n}'); do ip link show \"$i\" | grep -q 'UP' && addr=$(ip -4 -o addr show \"$i\" 2>/dev/null | awk '{print $4}' | cut -d/ -f1) && out=\"${out:+$out, }$i ($addr)\"; done; [ -n \"$out\" ] && echo \"🔒 $out\" || echo \"🔓 off\"",
        "interval": 5
    },

    "custom/bluetooth": {
        "exec": "if bluetoothctl show | grep -q 'Powered: yes'; then dev=$(bluetoothctl -- devices Connected 2>/dev/null | head -1 | cut -d' ' -f3-); echo \"🦷 ${dev:-on}\"; else echo \"🦷 off\"; fi",
        "interval": 1
    },

    "custom/volume": {
        "exec": "echo \"🔊 $(pactl get-sink-volume @DEFAULT_SINK@ | grep -oP '\\d+%' | head -1)\"",
        "interval": 1
    },

    "custom/disk": {
        "exec": "df -h | awk 'NR>1 && $NF==\"/\" {print \"💽 \" $1 \" - \" $5 \" of \" $2}'",
        "interval": 5
    },

    "custom/weather": {
        "exec": "~/scripts/weather.sh",
        "interval": 3600
    },

    "clock#date": {
        "format": "📆 {:%A %d %B}"
    },

    "clock#time": {
        "format": "🕙 {:%H:%M}",
        "interval": 1
    }
}
